FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/remote-chat .

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/remote-chat /remote-chat
EXPOSE 8787
ENTRYPOINT ["/remote-chat"]
